// Discord Bot Configuration
// Copy this file to config.js and fill in your actual values

module.exports = {
    // Your Discord bot token - Get this from https://discord.com/developers/applications
    token: 'YOUR_BOT_TOKEN_HERE',

    // Ticket System Configuration
    // Roles are looked up by name at runtime, so just make sure roles with these
    // names exist in your server. The ticket channel is set with /setup-tickets.

    moderatorRoleName: 'Moderator',  // Role used for moderators who can manage tickets
    verifiedRoleName: 'Verified',     // Role granted to verified users

    // Ticket Settings
    autoCloseAfterDays: 7  // Number of days before auto-closing inactive tickets
};
